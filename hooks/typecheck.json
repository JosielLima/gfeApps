{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": {
          "tool_name": "*",
          "file_paths": [
            "*.ts",
            "*.tsx"
          ]
        },
        "hooks": [
          {
            "type": "command",
            "command": "pnpm typecheck"
          }
        ]
      }
    ]
  }
}
